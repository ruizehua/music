#!/bin/sh
# 需求规范文档自动提交钩子
# 这个钩子会在提交前检查需求规范文档的变化

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 定义需要监控的文件
SPEC_FILES=("需求规范.md" "requirements.md" "spec.md")

echo "${GREEN}检查需求规范文档...${NC}"

# 检查是否有需求规范文档在暂存区
SPEC_IN_STAGING=0
for file in "${SPEC_FILES[@]}"; do
    if git diff --cached --name-only | grep -q "^$file$"; then
        echo "${YELLOW}发现需求规范文档变更: $file${NC}"
        SPEC_IN_STAGING=1
        break
    fi
done

# 如果需求规范文档有变更但未暂存，自动添加
for file in "${SPEC_FILES[@]}"; do
    if [ -f "$file" ] && ! git diff --cached --name-only | grep -q "^$file$" && ! git diff --name-only | grep -q "^$file$"; then
        # 文件存在且未变更
        continue
    elif [ -f "$file" ] && git diff --name-only | grep -q "^$file$"; then
        echo "${YELLOW}自动添加 $file 到暂存区${NC}"
        git add "$file"
        SPEC_IN_STAGING=1
    fi
done

# 检查 git 状态
git status

echo "${GREEN}pre-commit 钩子执行完成${NC}"
exit 0
